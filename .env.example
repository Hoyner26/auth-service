SPRING_PROFILES_ACTIVE=local
PORT=8080
FRONTEND_URL=http://localhost:5173
SESSION_EXPIRATION_HOURS=24

# Set this in Azure/Render app settings to auto-create the first admin.
ADMIN_EMAIL=admin@explorecr.com
ADMIN_PASSWORD=

# Render PostgreSQL profile
RENDER_POSTGRES_URL=jdbc:postgresql://host:5432/database
RENDER_POSTGRES_USER=user
RENDER_POSTGRES_PASSWORD=password

# Azure SQL profile (requires SQL Server migrations/driver adjustments)
AZURE_SQL_URL=jdbc:sqlserver://server.database.windows.net:1433;database=explorecr-users;encrypt=true
AZURE_SQL_USERNAME=user
AZURE_SQL_PASSWORD=password
